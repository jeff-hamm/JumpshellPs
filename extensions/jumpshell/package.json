{
  "name": "jumpshell",
  "displayName": "JumpShell",
  "description": "Install and manage JumpShell Copilot skills from VS Code or Cursor.",
  "version": "1.0.0",
  "publisher": "electric-pink",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/jeff-hamm/JumpshellPs.git",
    "directory": "extensions/jumpshell"
  },
  "engines": {
    "vscode": "^1.95.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "copilot",
    "skills",
    "agents",
    "jumpshell"
  ],
  "main": "./dist/extension.js",
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "commands": [
      {
        "command": "jumpshell.installSkills",
        "title": "Install Skills (Prompt on Conflicts)",
        "category": "JumpShell"
      },
      {
        "command": "jumpshell.updateSkills",
        "title": "Update Skills",
        "category": "JumpShell"
      },
      {
        "command": "jumpshell.installJumpshellMcp",
        "title": "Install MCP Configuration",
        "category": "JumpShell"
      },
      {
        "command": "jumpshell.configureJumpshell",
        "title": "Configure AI Backends",
        "category": "JumpShell"
      },
      {
        "command": "jumpshell.checkExtensionUpdates",
        "title": "Check GitHub VSIX Updates",
        "category": "JumpShell"
      },
      {
        "command": "jumpshell.selectModel",
        "title": "Select Chat Model",
        "category": "JumpShell"
      },
      {
        "command": "jumpshell.listModels",
        "title": "List Available Chat Models",
        "category": "JumpShell"
      },
      {
        "command": "jumpshell.sendPromptTo",
        "title": "Send Prompt to Model",
        "category": "JumpShell"
      },
      {
        "command": "jumpshell.assignModelHotkey",
        "title": "Assign Model Hotkey",
        "category": "JumpShell"
      }
    ],
    "configuration": {
      "title": "JumpShell",
      "properties": {
        "jumpshell.skillsPath": {
          "type": "string",
          "default": "~/.agents/skills",
          "description": "Directory where JumpShell installs Copilot skills. Use an absolute path or a path starting with ~/."
        },
        "jumpshell.installMcpOnSkillsInstall": {
          "type": "boolean",
          "default": false,
          "description": "Also install/update JumpShell MCP configuration after running Update Skills."
        },
        "jumpshell.installAiBackendsOnSkillsInstall": {
          "type": "boolean",
          "default": true,
          "description": "Also install/update ai_backends after running Update Skills."
        },
        "jumpshell.mcpConfigScope": {
          "type": "string",
          "enum": [
            "user",
            "workspace"
          ],
          "default": "user",
          "description": "Where JumpShell writes MCP configuration. 'user' writes the active profile user mcp.json. 'workspace' writes workspace mcp.json under .vscode or .cursor."
        },
        "jumpshell.workspaceMcpDirectory": {
          "type": "string",
          "enum": [
            "auto",
            "vscode",
            "cursor"
          ],
          "default": "auto",
          "description": "Workspace MCP directory when jumpshell.mcpConfigScope=workspace. 'auto' chooses by active editor and existing mcp.json files."
        },
        "jumpshell.moduleRootPath": {
          "type": "string",
          "default": "",
          "description": "Optional path to your JumpShell module root (or repo root). Leave blank to auto-detect."
        }
      }
    }
  },
  "scripts": {
    "build": "npm run sync:skills && tsc -p .",
    "check": "tsc -p . --noEmit",
    "watch": "tsc -w -p .",
    "sync:skills": "node ./scripts/sync-skills.mjs",
    "package": "vsce package",
    "vscode:prepublish": "npm run build"
  },
  "devDependencies": {
    "@types/node": "^25.4.0",
    "@types/vscode": "^1.95.0",
    "@vscode/vsce": "^3.7.1",
    "typescript": "^5.9.3"
  }
}







